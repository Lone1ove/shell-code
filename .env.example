# Environment variables for Shell Agent

# ============================================
# 运行模式
# ============================================
# 当前项目面向自动化渗透测试，建议固定为 pentest。
ENV_MODE=pentest

# Docker 执行器容器名
DOCKER_CONTAINER_NAME=kali-pentest

# 是否启用本地沙箱执行器。
# true: 某些执行器/环境会优先走本地沙箱。
# false: 按当前主流程直接使用项目既有执行链路。
SANDBOX_ENABLED=false

# ============================================
# 主模型（当前正式使用）
# ============================================
# 提供商名称，当前项目可直接用 GLM / openai 兼容端点。
# 如果你已经在 SiliconFlow 上接入 GLM，推荐保持为 GLM。
LLM_PROVIDER=GLM
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_API_KEY=sk-xxx
LLM_MODEL_NAME=Pro/zai-org/GLM-5

# ============================================
# 顾问模型（固定双智能体协作）
# ============================================
# 顾问模型建议使用更偏总结/复盘的模型。
ADVISOR_PROVIDER=MiniMax
ADVISOR_BASE_URL=https://api.siliconflow.cn/v1
ADVISOR_API_KEY=sk-xxx
ADVISOR_MODEL_NAME=Pro/MiniMaxAI/MiniMax-M2.5

# ============================================
# 任务目标与判定策略
# ============================================
# - hybrid: 检测优先（默认）
# - detect: 仅以漏洞检测为成功条件
# - flag: 仅以 FLAG 为成功条件
OBJECTIVE_MODE=hybrid

# CVE 验证阈值
SUSPECTED_THRESHOLD=0.45
CONFIRMED_THRESHOLD=0.80

# 默认关闭 benchmark 先验，避免 expected_cves / family 泄漏到推理链路
ENABLE_BENCHMARK_PRIORS=false

# ============================================
# 自适应二次复检 + 交集确认
# ============================================
ADAPTIVE_RECHECK_ENABLED=true
ADAPTIVE_RECHECK_TIMEOUT_SEC=240
ADAPTIVE_RECHECK_RECURSION_LIMIT=24
ADAPTIVE_RECHECK_SCORE_LOW=0.45
ADAPTIVE_RECHECK_SCORE_HIGH=0.85
ADAPTIVE_RECHECK_FP_TRIGGER=0.20

# ============================================
# 运行与稳定性参数
# ============================================
# 最大并发任务数。调大吞吐更高，但更容易把模型/工具打满。
MAX_CONCURRENT_TASKS=5
# 单目标失败后的自动重试次数。调大更稳，但总耗时会增加。
MAX_RETRIES=4
# 单目标允许的最大回合数上限。
MAX_ATTEMPTS=70
# LangGraph 递归上限，通常略高于 MAX_ATTEMPTS。
RECURSION_LIMIT=90
# 单目标总超时秒数。调大更有机会收敛，调小更容易提前停。
SINGLE_TASK_TIMEOUT=2000
# 主控连续几轮给不出可执行动作时，停止空转。
NO_ACTION_MAX_ROUNDS=5
# 顾问空转上限，避免 Advisor/Main 来回循环。
MAX_ADVISOR_LOOP_ROUNDS=4
# 连续失败多少次后要求顾问介入。
CONSECUTIVE_FAILURES_THRESHOLD=3
# 每隔多少轮主动咨询一次顾问。
ADVISOR_CONSULTATION_INTERVAL=5
# 是否启用失败后角色互换。当前架构建议保持 false。
ENABLE_ROLE_SWAP_RETRY=false

# 是否允许重新攻击已解决目标。
# true: 调试时可重复打已经成功过的目标。
# false: 正常运行时跳过已解决目标，避免重复劳动。
DEBUG_ALLOW_RESOLVED=false

# 本地目标映射：当目标为 127.0.0.1/localhost 时，容器内访问地址
LOCAL_TARGET_HOST=host.docker.internal

# LLM 超时与速率
MAIN_AGENT_LLM_TIMEOUT_SEC=150
ADVISOR_AGENT_LLM_TIMEOUT_SEC=150
EXECUTOR_AGENT_LLM_TIMEOUT_SEC=120
DEEPSEEK_REQUESTS_PER_SECOND=2.0
MINIMAX_REQUESTS_PER_SECOND=2.0

# 工作记忆与上下文控制
WORKING_MEMORY_CONTEXT_MAX_CHARS=3200
WORKING_MEMORY_RETRY_INJECT_MAX_CHARS=3600

# ============================================
# 工具输出总结与失败检测
# ============================================
# 是否启用工具输出总结（true/false）
# - true: 对长输出使用 LLM 总结，减少 token 消耗
# - false: 直接返回完整输出
ENABLE_TOOL_SUMMARY=true
# 工具输出总结阈值（字符数）
# 超过此长度的输出会被总结，默认 5000 字符
TOOL_SUMMARY_THRESHOLD=5000
# 是否启用 LLM 语义失败检测（true/false）
# - true: 使用 LLM 进行语义层面的失败检测
# - false: 使用关键字匹配
ENABLE_SMART_FAILURE_DETECTION=true

# ============================================
# CVE 匹配增强
# ============================================
# true: 先用本地 intel 缓存筛候选，本地候选不足时再用 RAG 补少量 CVE 候选。
# false: 只用本地 intel/template，不使用 RAG 参与 CVE 候选补充。
ENABLE_CVE_RAG_MATCHING=true

# RAG 候选数量：建议 3-6。
CVE_RAG_TOP_K=4

# RAG 最低严重度过滤：可选 low / medium / high / critical。
CVE_RAG_MIN_SEVERITY=low

# 本地 intel 初始候选上限：建议 4-8。
CVE_LOCAL_CANDIDATE_LIMIT=6

# 最终进入排序层的总候选上限：建议 6-10。
CVE_TOTAL_CANDIDATE_LIMIT=8

# 本地 intel 最低候选分数：建议 0.20-0.35。
CVE_LOCAL_MIN_SCORE=0.26

# 当本地高质量候选不超过多少个时，允许触发 RAG 补候选。
CVE_RAG_TRIGGER_MAX_LOCAL=2

# 如果本地最好候选分数已经达到这个值，则默认不再查 RAG。
CVE_RAG_SKIP_LOCAL_SCORE=0.72

# 如果本地前两名候选分差小于这个阈值，则允许查 RAG 做同族区分。
CVE_RAG_MARGIN_TRIGGER=0.08

# 从证据中抽取多少个向量/指纹关键词给 matcher 使用。
CVE_MATCH_VECTOR_TERM_LIMIT=8

# 顾问长时间空转后，禁用 RAG 的轮次阈值。
RAG_DISABLE_AFTER_ADVISOR_LOOPS=0
RAG_ALLOW_IN_REVIEW_MODE=true

# CVE-guided planning fallback
ENABLE_CVE_TASK_GUIDANCE=true
CVE_TASK_GUIDANCE_TOP_K=3
CVE_TASK_GUIDANCE_FETCH_TOP_K=6
CVE_TASK_GUIDANCE_MIN_SEVERITY=low
AUTO_CVE_FALLBACK_MAX_TOOL_ROUNDS=6

# transport-error retry control (main planner fallback window)
TRANSPORT_RETRY_ROUND_WINDOW=4

# ============================================
# 可观测性
# ============================================
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

# ============================================
# CVE 情报增强
# ============================================
# NVD API Key：可选，但配置后 NVD 拉取更稳定。
NVD_API_KEY=

# GitHub Token：可选，用于拉 GitHub PoC 仓库，未配置时容易被限流。
GITHUB_TOKEN=

# 自定义漏洞族模板路径：一般留空，默认使用 data/cve_templates/families.json。
CVE_TEMPLATE_RULES_PATH=

# Benchmark 种子路径：一般无需修改，主要用于本地已知 benchmark/靶场 CVE 种子补充。
BENCHMARK_CVE_SEED_PATH=benchmarks/known_cve_targets.json

# 主流高危 CVE 种子路径：留空则使用项目默认种子文件。
MAINSTREAM_CVE_SEED_PATH=

# 是否把本地 vulhub 里的 CVE 信息也作为 intel 种子导入。
ENABLE_VULHUB_SEED=true

# vulhub 根目录：留空时默认尝试使用项目同级目录下的 vulhub。
VULHUB_ROOT=

# 扫描 vulhub 文件数上限：0 表示使用代码默认值。
VULHUB_SEED_MAX_FILES=0

# ============================================
# 技能加载
# ============================================
EXTRA_SKILL_DIRS=
MIN_SKILL_CONTEXT_SCORE=8

# ============================================
# 兼容开关（默认关闭比赛工具）
# ============================================
ENABLE_COMPETITION_TOOLS=false
